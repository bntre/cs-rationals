@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using SkiaSharp.Views.Blazor
@using MudBlazor
@using Rationals.Explorer.Blazor


<script>
// Prevent the default browser zoom
window.addEventListener('wheel', function (e) {
    if (e.ctrlKey) e.preventDefault();
}, { passive: false });
</script>


<MudThemeProvider DefaultScrollbar="true" />
<!--
<MudDialogProvider/>
<MudSnackbarProvider/>
-->

<MudLayout>

    <MudAppBar>
        <MudIconButton Icon="@Icons.Material.Filled.Menu" OnClick="@ToggleSidebar" />
    <!--
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" />
        <MudSpacer />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" />
    -->
        My Application
    </MudAppBar>

    <MudDrawer @bind-Open="_sidebarOpen" Elevation="1" Variant="@DrawerVariant.Persistent">
        <MudText Typo="Typo.h6">Sidebar</MudText>
        <MudNavMenu>
            <MudNavLink>Control 1</MudNavLink>
            <MudNavLink>Control 2</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <div style="width: 100%; height: 100vh;">
            <SKCanvasView
                Style="@($"cursor: {currentCursor}; width:800px; height:600px;")"
                IgnorePixelScaling="true"
                OnPaintSurface="OnPaintSurface"
                @ref="skCanvas"
                @onmousemove="HandleMouseMove"
                @onmouseleave="HandleMouseLeave"
                @onpointerdown="HandlePointerDown"
                @onpointerup="HandlePointerUp"
                @onwheel="HandleWheel"
                @onkeydown="HandleKeyDown"
                @onkeyup="HandleKeyUp"
            />
        </div>
    </MudMainContent>

</MudLayout>
